---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Direction Study: Warm / Grace-Filled"
  description="A warm and grace-filled homepage direction study for mission-driven organizations."
  pageClass="concept-familiar"
  showConceptSwitcher={true}
  activeConcept="familiar"
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Direction Study</p>
        <h1>Warm / Grace-Filled</h1>
        <p>
          This direction leads with welcome, emotional safety, and relational clarity. It is designed to reduce
          friction for first-time visitors while still offering clear pathways for returning users.
        </p>
        <div class="cta-row">
          <a class="btn" href={`${base}website-strategy-catalog#warm-grace`}>View in Catalog</a>
          <a class="btn btn-soft" href={`${base}website-strategy-catalog#decision-framework`}>Use Decision Framework</a>
        </div>
      </div>
      <div class="image-placeholder hero-image">Soft hero with welcoming headline and gentle action prompts</div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Design Notes</p>
        <h2>What This Direction Prioritizes</h2>
        <span class="accent-bar"></span>
      </div>
      <div class="cards-grid stagger">
        <article class="info-card">
          <h3>Tone</h3>
          <p>Welcoming, calm, and human. Language is invitational rather than urgent.</p>
        </article>
        <article class="info-card">
          <h3>Hero Style</h3>
          <p>Centered or softly split hero with clear emotional framing and low-pressure CTAs.</p>
        </article>
        <article class="info-card">
          <h3>Best Fit</h3>
          <p>Organizations where reassurance and trust-building are the first priority.</p>
        </article>
        <article class="info-card">
          <h3>CTA Pattern</h3>
          <p>Gentle dual actions such as “Learn More” and “Get Connected.”</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container concept-study-panel concept-study-panel--warm">
      <div>
        <p class="eyebrow">Sample Composition</p>
        <h2>Homepage Slice</h2>
        <p>
          The layout gives breathing room to headline copy, support text, and simple next steps. Supporting cards
          reinforce belonging and practical guidance without overwhelming the page.
        </p>
      </div>
      <div class="concept-study-preview" role="img" aria-label="Warm concept homepage composition preview">
        <div class="preview-hero preview-hero--center">
          <p class="preview-eyebrow">Welcome</p>
          <p class="preview-headline">A Place to Begin with Confidence</p>
          <p class="preview-support">Clear guidance for new and returning visitors.</p>
        </div>
        <div class="preview-row preview-row--three">
          <div class="preview-card">First Steps</div>
          <div class="preview-card">Community</div>
          <div class="preview-card">Support</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
