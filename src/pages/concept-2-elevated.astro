---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Direction Study: Grounded / Earth-Toned"
  description="A grounded and earth-toned homepage direction study for mission-driven organizations."
  pageClass="concept-elevated"
  showConceptSwitcher={true}
  activeConcept="elevated"
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Direction Study</p>
        <h1>Grounded / Earth-Toned</h1>
        <p>
          This direction emphasizes trust, steadiness, and long-term credibility. It uses warmer neutrals,
          measured hierarchy, and narrative pacing to communicate maturity and depth.
        </p>
        <div class="cta-row">
          <a class="btn" href={`${base}website-strategy-catalog#grounded-earth`}>View in Catalog</a>
          <a class="btn btn-soft" href={`${base}website-strategy-catalog#decision-framework`}>Use Decision Framework</a>
        </div>
      </div>
      <div class="image-placeholder hero-image">Layered hero with grounded surfaces and slower visual rhythm</div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Design Notes</p>
        <h2>What This Direction Prioritizes</h2>
        <span class="accent-bar"></span>
      </div>
      <div class="pillars-grid stagger">
        <article class="pillar-card">
          <h3>Tone</h3>
          <p>Thoughtful, reliable, and grounded. Messaging supports confidence over urgency.</p>
        </article>
        <article class="pillar-card">
          <h3>Hero Style</h3>
          <p>Split or narrative-led hero with supporting context blocks and restrained typography.</p>
        </article>
        <article class="pillar-card">
          <h3>Best Fit</h3>
          <p>Organizations that need to signal trust, care, and long-term commitment.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container concept-study-panel concept-study-panel--earth">
      <div>
        <p class="eyebrow">Sample Composition</p>
        <h2>Homepage Slice</h2>
        <p>
          This study combines a narrative hero block with structured content rows. The goal is to help visitors feel
          both emotionally reassured and practically informed.
        </p>
      </div>
      <div class="concept-study-preview" role="img" aria-label="Grounded concept homepage composition preview">
        <div class="preview-split">
          <div class="preview-split__copy">
            <p class="preview-eyebrow">Steady Presence</p>
            <p class="preview-headline">Built for Trust, Not Noise</p>
            <p class="preview-support">Measured storytelling with clear informational flow.</p>
          </div>
          <div class="preview-split__surface" aria-hidden="true"></div>
        </div>
        <div class="preview-row preview-row--two">
          <div class="preview-card">Programs</div>
          <div class="preview-card">Support Paths</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
