    previewSupport: 'A calm, supportive structure that prioritizes emotional clarity.',
    toneClass: 'airy',
    ctaLabel: 'Pattern CTA: Learn More'
  },
  {
    id: 'grounded-earth',
    name: 'Grounded / Earth-Toned',
    summary: 'A steady, trustworthy direction with more weight, depth, and compositional maturity.',
    emphasis: 'Earth-influenced tones and layered sections reinforce reliability and long-term presence.',
    idealUse: 'Best when trust, steadiness, and thoughtful communication are central to the organization.',
    tone: 'Grounded, thoughtful, steady',
    bestFit: 'Teams emphasizing credibility, care, and continuity',
    heroApproach: 'Narrative-led split hero with contextual support',
    ctaStyle: 'Guided and contextual',
    visualFeel: 'Warm depth, restrained rhythm, stable hierarchy',
    previewPattern: 'earth',
    previewHeadline: 'Helping People Find Hope and Community',
    previewSupport: 'Built to convey trust over time, not flash in the first second.',
    toneClass: 'earth',
    ctaLabel: 'Pattern CTA: Explore Support Paths'
  },
  {
    id: 'raw-contrast',
    name: 'Raw Contrast / High Contrast Modern',
    summary: 'A sharp, modern direction where message hierarchy and action pathways are unmistakable.',
    emphasis: 'High contrast, minimal noise, and assertive typography create rapid comprehension.',
    idealUse: 'Best when the site must feel clear, confident, modern, and immediately actionable.',
    tone: 'Direct, confident, modern',
    bestFit: 'Organizations prioritizing clarity and momentum',
    heroApproach: 'Typography-led, message-first hero',
    ctaStyle: 'Focused and explicit',
    visualFeel: 'Crisp, bold, high-contrast',
    previewPattern: 'high-contrast',
    previewHeadline: 'Lead With What Matters Most',
    previewSupport: 'Direct hierarchy that points visitors to the right next step fast.',
    toneClass: 'contrast',
    ctaLabel: 'Pattern CTA: Start Here'
  },
  {
    id: 'light-airy',
    name: 'Light and Airy',
    summary: 'A bright, balanced direction with open breathing room and gentle visual rhythm.',
    emphasis: 'Whitespace and soft neutrals keep the page clear while maintaining warmth and polish.',
    idealUse: 'Best for teams wanting accessibility and welcome without heavy emotional framing.',
    tone: 'Clear, calm, balanced',
    bestFit: 'Organizations needing an approachable but polished baseline',
    heroApproach: 'Open hero with concise supporting context',
    ctaStyle: 'Invitational with low pressure',
    visualFeel: 'Lightweight, breathable, refined',
    previewPattern: 'airy',
    previewHeadline: 'Clarity Without Coldness',
    previewSupport: 'A balanced layout for organizations that need warmth and precision together.',
    toneClass: 'airy',
    ctaLabel: 'Pattern CTA: See Overview'
  },
  {
    id: 'bold-mission',
    name: 'Bold Mission Forward',
    summary: 'A mission-first direction designed to increase momentum and emphasize immediate action.',
    emphasis: 'Large statements, strong pathways, and high-visibility CTAs reduce hesitation.',
    idealUse: 'Best when campaigns, enrollment, participation, or action goals are primary.',
    tone: 'Energetic, directional, decisive',
    bestFit: 'Teams needing stronger conversion and movement',
    heroApproach: 'Large left-aligned mission statement',
