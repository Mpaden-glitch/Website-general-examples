    emphasis: 'The page unfolds in chapters, using meaning and context to build trust progressively.',
    idealUse: 'Best when transformation stories, mission narrative, or lived impact are central to positioning.',
    tone: 'Reflective, human, emotional',
    bestFit: 'Teams whose credibility is strengthened by story depth',
    heroApproach: 'Narrative hero leading into chaptered sections',
    ctaStyle: 'Contextual and progressive',
    visualFeel: 'Editorial flow with emotional continuity',
    previewPattern: 'story',
    previewHeadline: 'Every Journey Starts Somewhere',
