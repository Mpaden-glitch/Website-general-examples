---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const concepts = [
  {
    title: 'Concept 1: Warm Minimal (Familiar)',
    tag: 'Welcoming · Soft Rhythm · Clear Steps',
    text: 'A family-friendly direction with gentle spacing, rounded cards, and clear first-time pathways designed to feel like a personal invitation.',
    href: `${base}concept-1-familiar`
  },
  {
    title: 'Concept 2: Editorial Grace (Elevated)',
    tag: 'Editorial · Mission-Led · Premium',
    text: 'A refined, serif-led composition with intentional whitespace and structured storytelling that feels polished while staying pastoral.',
    href: `${base}concept-2-elevated`
  },
  {
    title: 'Concept 3: Raw Contrast (Bold)',
    tag: 'High Contrast · Direct · Authentic',
    text: 'A modern and confident direction driven by scale, contrast, and short direct language, with clear steps for people who want to act now.',
    href: `${base}concept-3-bold`
  }
];
---

<BaseLayout
  title="Limitless Church Homepage Concepts"
  description="Three strategic homepage design directions for Limitless Church in Nixa, Missouri."
  pageClass="concept-index"
>
  <section class="selector-hero">
    <div class="container">
      <p class="eyebrow">Strategy Mockup · Limitless Church, Nixa MO</p>
      <h1>Three Homepage Directions</h1>
      <span class="accent-bar"></span>
      <p style="margin-top: 1.1rem;">
        Each concept explores how structure, copy, and visual rhythm can communicate warmth and
        belonging in a black, white, and neutral design system. The three directions differ in
        flow, tone, density, and emotional posture through typography, spacing, and composition.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container selector-grid">
      {concepts.map((concept) => (
        <article class="concept-card">
          <span class="concept-tag">{concept.tag}</span>
          <h2>{concept.title}</h2>
          <p>{concept.text}</p>
          <a class="btn" href={concept.href}>View Concept</a>
        </article>
      ))}
    </div>

    <p class="container selector-note">
      All three concepts are static, fast, and GitHub Pages friendly.
      The church mission, to help people encounter God, love people, and find purpose, runs
      through every direction, expressed differently by each one.
    </p>
  </section>
</BaseLayout>
