---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const concepts = [
  {
    title: 'Concept 1: Familiar',
    tag: 'Welcoming · Clear · Refined',
    text: 'The closest to what the church could adopt without fear. Stronger copy, numbered steps, and improved hierarchy — but familiar in structure and tone.',
    href: `${base}concept-1-familiar`
  },
  {
    title: 'Concept 2: Elevated',
    tag: 'Mission-Shaped · Editorial · Mature',
    text: 'The mission statement leads the page. Color-coded pillars, a journey pathway, and serif typography give this concept a more intentional, production-grade feel.',
    href: `${base}concept-2-elevated`
  },
  {
    title: 'Concept 3: Bold',
    tag: 'Distinct · Local · Community-Forward',
    text: 'Opens with a full-width emotional declaration before the hero. Dark treatment, assertive copy, and a stronger sense of local church identity than a platform-driven template.',
    href: `${base}concept-3-bold`
  }
];
---

<BaseLayout
  title="Limitless Church Homepage Concepts"
  description="Three strategic homepage design directions for Limitless Church in Nixa, Missouri."
  pageClass="concept-index"
>
  <section class="selector-hero">
    <div class="container">
      <p class="eyebrow">Strategy Mockup · Limitless Church, Nixa MO</p>
      <h1>Three Homepage Directions</h1>
      <span class="accent-bar"></span>
      <p style="margin-top: 1.1rem;">
        Each concept explores how structure, copy, and visual rhythm can communicate warmth and
        belonging without relying on homepage video. The three directions differ in flow, tone,
        density, and emotional posture — not just color.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container selector-grid">
      {concepts.map((concept) => (
        <article class="concept-card">
          <span class="concept-tag">{concept.tag}</span>
          <h2>{concept.title}</h2>
          <p>{concept.text}</p>
          <a class="btn" href={concept.href}>View Concept</a>
        </article>
      ))}
    </div>

    <p class="container selector-note">
      All three concepts are static, fast, and GitHub Pages friendly.
      The church mission — to help people encounter God, love people, and find purpose — runs
      through every direction, expressed differently by each one.
    </p>
  </section>
</BaseLayout>
