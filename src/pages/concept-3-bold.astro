---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Direction Study: Raw Contrast / High Contrast Modern"
  description="A raw contrast and high-contrast modern homepage direction study for mission-driven organizations."
  pageClass="concept-bold"
  showConceptSwitcher={true}
  activeConcept="bold"
>
  <section class="welcome-band">
    <div class="container welcome-band-inner">
      <p class="eyebrow">Direction Study</p>
      <h1>Raw Contrast / High Contrast Modern</h1>
      <p>
        This direction leads with decisive hierarchy, high contrast, and direct messaging. It is designed for teams
        that need immediate clarity and stronger momentum toward next steps.
      </p>
      <div class="cta-row">
        <a class="btn" href={`${base}website-strategy-catalog#raw-contrast`}>View in Catalog</a>
        <a class="btn btn-soft" href={`${base}website-strategy-catalog#decision-framework`}>Use Decision Framework</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Design Notes</p>
        <h2>What This Direction Prioritizes</h2>
        <span class="accent-bar"></span>
      </div>
      <div class="journey-grid">
        <article class="journey-step">
          <span class="journey-step-num">01</span>
          <h3>Tone</h3>
          <p>Direct, clear, and confident. Minimal decorative noise.</p>
        </article>
        <article class="journey-step">
          <span class="journey-step-num">02</span>
          <h3>Hero Style</h3>
          <p>Headline-first with short support copy and one obvious action path.</p>
        </article>
        <article class="journey-step">
          <span class="journey-step-num">03</span>
          <h3>Best Fit</h3>
          <p>Organizations prioritizing immediate clarity, action, and modern confidence.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container concept-study-panel concept-study-panel--contrast">
      <div>
        <p class="eyebrow">Sample Composition</p>
        <h2>Homepage Slice</h2>
        <p>
          The contrast system allows visitors to scan quickly and understand what to do next. Section rhythm is tight,
          typography is assertive, and calls to action are visually unambiguous.
        </p>
      </div>
      <div class="concept-study-preview" role="img" aria-label="Raw contrast concept homepage composition preview">
        <div class="preview-contrast-nav">
          <span>Mission</span>
          <span>Pathways</span>
          <span>Action</span>
        </div>
        <div class="preview-hero preview-hero--left">
          <p class="preview-eyebrow">Clarity First</p>
          <p class="preview-headline">Say Less, Guide Better</p>
          <p class="preview-support">Fast comprehension with direct next-step structure.</p>
          <span class="preview-chip">Take the Next Step</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
