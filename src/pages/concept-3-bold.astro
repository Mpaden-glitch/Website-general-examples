---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Concept 3: Bold | Limitless Church"
  pageClass="concept-bold"
  showConceptSwitcher={true}
  activeConcept="bold"
>

  <!-- Welcome band — full-width, typography-forward, emotional opener -->
  <section class="welcome-band">
    <div class="container welcome-band-inner">
      <p class="eyebrow" style="color: rgba(240, 144, 80, 0.85);">Limitless Church · Nixa, Missouri</p>
      <h1>This Is a Church<br>Where You Belong<br>Before You Believe.</h1>
      <p>
        Belonging isn't something you earn here. It's the starting point.
        Come with your questions, your mess, your family, or just yourself.
        Sunday is open.
      </p>
      <div class="cta-row">
        <a class="btn" href="#" style="background: var(--accent); color: #fff;">Plan Your Visit</a>
        <a class="btn btn-soft" href="#" style="border-color: rgba(255,255,255,0.25); color: rgba(232, 239, 248, 0.9);">Watch a Message</a>
      </div>
    </div>
  </section>

  <!-- Sunday at a Glance — strong stat bar -->
  <div class="sunday-bar">
    <div class="container sunday-bar-inner">
      <div class="sunday-stat">
        <span class="sunday-stat-value">9:00</span>
        <span class="sunday-stat-label">First Service</span>
      </div>
      <div class="sunday-stat">
        <span class="sunday-stat-value">10:45</span>
        <span class="sunday-stat-label">Second Service</span>
      </div>
      <div class="sunday-stat">
        <span class="sunday-stat-value">Nixa, MO</span>
        <span class="sunday-stat-label">Location</span>
      </div>
      <div class="sunday-stat">
        <span class="sunday-stat-value">All Ages</span>
        <span class="sunday-stat-label">Kids &amp; Youth</span>
      </div>
      <div class="sunday-stat">
        <span class="sunday-stat-value">Free</span>
        <span class="sunday-stat-label">Parking Always</span>
      </div>
    </div>
  </div>

  <!-- Hero — secondary, more personal, grounded -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">A Real Church</p>
        <h1>Not Polished.<br>Just Present.</h1>
        <p>
          We're not trying to be the biggest church in Springfield or the coolest
          church on the internet. We're committed to being a real, present community
          for people in Nixa, Missouri.
        </p>
        <div class="cta-row">
          <a class="btn" href="#">Come See for Yourself</a>
        </div>
      </div>
      <div class="image-placeholder hero-image">People gathering outside — real community image</div>
    </div>
  </section>

  <!-- Mission Journey — vertical stacked steps, strong visual rhythm -->
  <section class="section">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Mission</p>
        <h2>Encounter. Love. Purpose.</h2>
        <span class="accent-bar"></span>
        <p style="margin-top: 1rem;">
          Three words we take seriously. Not as a tagline — as an actual
          framework for how we live and grow together.
        </p>
      </div>

      <div class="journey-grid">
        <article class="journey-step">
          <span class="journey-step-num">01</span>
          <h3>Encounter God</h3>
          <p>
            Sundays at Limitless aren't a performance. They're an invitation — to
            worship, to hear Scripture taught plainly, and to experience something
            real. We believe God shows up when people show up together.
          </p>
        </article>
        <article class="journey-step">
          <span class="journey-step-num">02</span>
          <h3>Love People</h3>
          <p>
            This church is built on people choosing each other — in groups, in
            care, in everyday generosity. Community isn't what happens after service.
            It's the whole point.
          </p>
        </article>
        <article class="journey-step">
          <span class="journey-step-num">03</span>
          <h3>Find Purpose</h3>
          <p>
            Everyone has something to contribute. Serve teams, growth paths, and
            next steps exist to help people find their place and put their gifts
            to work in a way that actually matters.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Community life — two-column alternating -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Community Life</p>
        <h2>What Keeps People Coming Back</h2>
        <span class="accent-bar"></span>
      </div>

      <div class="split-grid" style="margin-bottom: 2rem;">
        <div>
          <p class="eyebrow" style="margin-bottom: 0.5rem;">Kids &amp; Youth</p>
          <h3 style="font-size: clamp(1.2rem, 2.5vw, 1.8rem); margin-bottom: 0.75rem;">The Next Generation Actually Belongs Here</h3>
          <p style="color: var(--text-soft); line-height: 1.65; margin-bottom: 1rem; font-size: 0.97rem;">
            Kids church and student ministry aren't holding tanks while adults do the
            real stuff. They're environments designed to help the next generation
            encounter God in ways that make sense for them.
          </p>
          <a class="btn btn-soft" href="#">Explore Next Gen</a>
        </div>
        <div class="image-placeholder image-tall">Kids &amp; youth ministry image</div>
      </div>

      <div class="split-grid" style="direction: ltr;">
        <div class="image-placeholder image-tall">Small group community image</div>
        <div>
          <p class="eyebrow" style="margin-bottom: 0.5rem;">Groups &amp; Community</p>
          <h3 style="font-size: clamp(1.2rem, 2.5vw, 1.8rem); margin-bottom: 0.75rem;">Smaller Groups Make the Church Feel Human</h3>
          <p style="color: var(--text-soft); line-height: 1.65; margin-bottom: 1rem; font-size: 0.97rem;">
            A church of hundreds still needs the intimacy of twelve. Midweek groups
            are where people stop being faces in the crowd and start being
            people who are known.
          </p>
          <a class="btn btn-soft" href="#">Find a Group</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Community facts — stated truths, not generic testimonials -->
  <div class="community-facts">
    <div class="container community-facts-inner">
      <div class="community-fact-item">
        <strong>10+</strong>
        <span>Years rooted in Nixa and the surrounding community</span>
      </div>
      <div class="community-fact-item">
        <strong>Every Sunday</strong>
        <span>Two services, kids environments, and a team glad to see you</span>
      </div>
      <div class="community-fact-item">
        <strong>No Script</strong>
        <span>No pressure to perform, give, or have answers before you're ready</span>
      </div>
      <div class="community-fact-item">
        <strong>Real People</strong>
        <span>A congregation made up of families, singles, skeptics, and seekers</span>
      </div>
    </div>
  </div>

  <!-- Local identity -->
  <section class="local-band">
    <div class="container">
      <div class="local-shell">
        <div>
          <p class="eyebrow">One Church, One City</p>
          <h2>Rooted in Nixa, Missouri</h2>
          <p>
            We're not trying to be everywhere. We're committed to Nixa. That means
            knowing our neighbors, caring about local schools and families, and
            building something that matters to this specific city — not just the
            internet version of church.
          </p>
          <p>
            When you show up at Limitless, you're joining something that belongs
            to this place.
          </p>
          <div class="cta-row" style="margin-top: 0.5rem;">
            <a class="btn btn-soft" href="#">About Our Church</a>
          </div>
        </div>
        <div class="image-placeholder image-tall">Nixa community + local church life image</div>
      </div>
    </div>
  </section>

  <!-- CTA — bold, assertive copy -->
  <section class="cta-group section">
    <div class="container">
      <div class="cta-panel">
        <p class="eyebrow">You're Invited</p>
        <h2>Come See for Yourself This Sunday</h2>
        <p>
          Bring your questions. Bring your family. Bring your skepticism.
          We're not asking you to believe anything before you walk in.
          Just come. Services at 9:00 AM and 10:45 AM in Nixa.
        </p>
        <div class="cta-row">
          <a class="btn" href="#">Plan Your Visit</a>
          <a class="btn btn-soft" href="#">Watch a Message First</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
