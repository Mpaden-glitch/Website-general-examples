---
interface Props {
  showConceptSwitcher?: boolean;
  activeConcept?: 'familiar' | 'elevated' | 'bold';
}

const { showConceptSwitcher = false, activeConcept } = Astro.props;
const base = import.meta.env.BASE_URL;

const navLinks = [
  { label: 'Home', href: base },
  { label: 'About', href: '#' },
  { label: 'Ministries', href: '#' },
  { label: 'Messages', href: '#' },
  { label: 'Plan Your Visit', href: '#' }
];

const conceptLinks = [
  { key: 'familiar', label: 'Concept 1: Familiar', href: `${base}concept-1-familiar` },
  { key: 'elevated', label: 'Concept 2: Elevated', href: `${base}concept-2-elevated` },
  { key: 'bold', label: 'Concept 3: Bold', href: `${base}concept-3-bold` }
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={base} aria-label="Limitless Church concepts home">
      <span class="brand-mark" aria-hidden="true">LC</span>
      <span>Limitless Church</span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <a class="btn btn-soft header-cta" href="#">Plan Your Visit</a>
  </div>

  {
    showConceptSwitcher && (
      <div class="concept-switcher-wrap">
        <div class="container concept-switcher" role="navigation" aria-label="Concept pages">
          {conceptLinks.map((concept) => (
            <a
              href={concept.href}
              class:list={{
                active: activeConcept === concept.key
              }}
            >
              {concept.label}
            </a>
          ))}
        </div>
      </div>
    )
  }
</header>
