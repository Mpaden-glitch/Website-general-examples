---
interface Props {
  showConceptSwitcher?: boolean;
  activeConcept?: 'familiar' | 'elevated' | 'bold';
  variant?: 'default' | 'neutral';
}

const { showConceptSwitcher = false, activeConcept } = Astro.props;
const base = import.meta.env.BASE_URL;
const foundationMileHref = import.meta.env.PUBLIC_FOUNDATION_MILE_URL || 'https://foundationalmile.com/';

const navLinks = [
  { label: 'Home', href: base },
  { label: 'Website Catalog', href: `${base}website-strategy-catalog` },
  { label: 'Direction Studies', href: `${base}concept-1-familiar` },
  { label: 'Method', href: '#' }
];

const conceptLinks = [
  { key: 'familiar', label: 'Warm / Grace-Filled', href: `${base}concept-1-familiar` },
  { key: 'elevated', label: 'Grounded / Earth-Toned', href: `${base}concept-2-elevated` },
  { key: 'bold', label: 'Raw Contrast / Modern', href: `${base}concept-3-bold` }
];
---

<header class="site-header">
  <div class="header-return-wrap">
    <div class="container header-return">
      <span>Viewing the Website Strategy Showcase</span>
      <a class="btn btn-soft header-return-btn" href={foundationMileHref}>Back to Foundation Mile</a>
    </div>
  </div>

  <div class="container header-inner">
    <a class="brand" href={base} aria-label="Mission-driven website strategy showcase home">
      <span class="brand-mark" aria-hidden="true">WS</span>
      <span>Website Strategy Showcase</span>
    </a>

    <nav class="main-nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <a class="btn btn-soft header-cta" href="#">Start with Strategy</a>
  </div>

  {
    showConceptSwitcher && (
      <div class="concept-switcher-wrap">
        <div class="container concept-switcher" role="navigation" aria-label="Direction studies">
          {conceptLinks.map((concept) => (
            <a
              href={concept.href}
              class:list={{
                active: activeConcept === concept.key
              }}
            >
              {concept.label}
            </a>
          ))}
        </div>
      </div>
    )
  }
</header>
