---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  center?: boolean;
}

const { eyebrow, title, text, center = false } = Astro.props;
---

<div class:list={{ 'section-heading': true, center }}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {text && <p>{text}</p>}
</div>
